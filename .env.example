# ── Quant AI Terminal — environment template (copy to .env) ──
# No real secrets here; replace placeholders before use.

# Database (TimescaleDB / Postgres)
TIMESCALEDB_URL=postgresql+asyncpg://quant:CHANGE_ME@db:5432/forex
# Redis (pub/sub + cache + rate limiter)
REDIS_URL=redis://redis:6379/0

# Binance crypto symbols (live ticks)
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# AI model files (optional — degrade gracefully if missing)
MODEL_DIR=/app/models
TFT_MODEL_PATH=/app/models/tft_v3.pt
LGBM_MODEL_PATH=/app/models/lgbm_features.pkl
SCALER_PATH=/app/models/scalers.pkl
DEVICE=cpu

# FinBERT sentiment
FINBERT_MODEL=ProsusAI/finbert
FINBERT_DEVICE=cpu

# Risk management
MAX_DRAWDOWN_PCT=0.05
TARGET_VOLATILITY=0.10
RISK_PER_TRADE_PCT=0.01
MIN_CONFIDENCE_THRESHOLD=0.65
CIRCUIT_BREAKER_COOLDOWN_HOURS=24

# Image analysis
MAX_UPLOAD_SIZE_MB=10
TESSERACT_CMD=/usr/bin/tesseract

# CORS — set to your deployed frontend origin (e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:3000

APP_ENV=production
LOG_LEVEL=INFO

# Forex / commodities (always enabled for analysis + selectable symbols)
ENABLE_FOREX=true
ENABLE_COMMODITIES=true
COMMODITIES=XAUUSD

# News feed (optional; leave blank for curated offline set)
# NEWS_API_URL=
# NEWS_API_KEY=
NEWS_CACHE_TTL=900

# Chat assistant + LLM reasoning plane
CHAT_ENABLED=true
# LLM_PROVIDER: hybrid (cloud -> ollama -> off) | cloud | ollama | off
LLM_PROVIDER=hybrid
# Cloud (OpenAI-compatible): OpenAI, DeepSeek, Groq, Together, ...
LLM_CLOUD_BASE_URL=https://api.openai.com/v1
LLM_CLOUD_API_KEY=
LLM_CLOUD_MODEL=gpt-4o-mini
# Local Ollama (private, no token cost) — e.g. http://ollama:11434 in compose
LLM_OLLAMA_URL=http://localhost:11434
LLM_OLLAMA_MODEL=llama3.1:8b
LLM_TIMEOUT=30
LLM_MAX_TOKENS=600
LLM_TEMPERATURE=0.3

# Live forex / commodity feed (pluggable MarketSource)
FOREX_SOURCE=live_rates
LIVERATES_API_KEY=
LIVERATES_POLL_INTERVAL=2.0

# Rate limiter: use shared Redis sliding-window (false => in-process only)
RATE_LIMIT_REDIS_ENABLED=true

# API authentication (standard 2.2). Disabled by default; enable in production
# and set a strong API_KEY (or comma-separated API_KEYS). The frontend sends
# NEXT_PUBLIC_API_KEY as the X-API-Key header. When enabled, all routes except
# /healthz, /readyz, /metrics and /docs require the key; the WS upgrade too.
API_AUTH_ENABLED=false
API_KEY=
API_KEYS=
API_KEY_HEADER=X-API-Key

# Frontend public API key (sent as X-API-Key). Set to the same value as API_KEY.
NEXT_PUBLIC_API_KEY=
